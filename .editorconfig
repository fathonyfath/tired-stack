root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,cjs,mjs,css}]
indent_style = space
indent_size = 2

[*.kt]
indent_style = space
indent_size = 4
max_line_length = 120
ij_kotlin_packages_to_use_import_on_demand = kotlinx.html.*

[*.{gradle,gradle.kts}]
indent_style = space
indent_size = 4

[*.{json,toml,yml,yaml}]
indent_style = space
indent_size = 2
